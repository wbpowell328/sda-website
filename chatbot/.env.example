# Copy this file to ".env" (no extension prefix) and paste your real key.
# Never commit the real .env file — it is in .gitignore.

# Get your API key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Voyage AI key for embeddings (free tier: 200M tokens). Sign up at
# https://www.voyageai.com — Anthropic's recommended embedding provider.
# Used by ingest.js and the RAG retrieval layer.
VOYAGE_API_KEY=pa-your-voyage-key-here

# Turso (hosted SQLite) for conversation logging. Sign up free at
# https://turso.tech. If both are unset, logging is silently disabled and
# /admin/conversations returns 503.
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-turso-jwt-token

# Password for the /admin/conversations page. Pick something memorable.
ADMIN_PASSWORD=change-me

# Salt for hashing client IPs in the log. Any random string works.
IP_HASH_SALT=change-me-too

# Which Claude model to use. Defaults to Haiku 4.5 — fast and cheap, ideal for chat.
# Other options:
#   claude-sonnet-4-6   (smarter, ~3x cost)
#   claude-opus-4-7     (smartest, ~15x cost — overkill for most chats)
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Port the local server listens on. Default 3000.
PORT=3000

# Comma-separated list of origins allowed to hit the API.
# Leave empty during local development to allow any origin.
ALLOWED_ORIGINS=
